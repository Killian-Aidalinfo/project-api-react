# --- Variables consommées par compose.yaml (à définir dans Coolify en prod) ---
# En local : copier ce fichier en .env (ignoré par git) et ajuster les valeurs.

# Port d'écoute de l'API (hôte + conteneur)
PORT=3000

# Base MySQL — RENSEIGNER DE VRAIS SECRETS EN PROD (côté Coolify)
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=atelier
MYSQL_USER=atelier
MYSQL_PASSWORD=change-me

# Port hôte d'exposition de MySQL (dev local uniquement)
MYSQL_PORT=3306

# --- Variables internes lues par l'API (déjà dérivées dans compose.yaml) ---
# Utiles seulement si tu lances l'API hors compose (bun run dev) :
DB_HOST=localhost
DB_PORT=3306
DB_USER=atelier
DB_PASSWORD=change-me
DB_NAME=atelier
